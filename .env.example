# Application
APP_ENV=development
LOG_LEVEL=INFO

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# OpenSearch
OPENSEARCH_HOST=
OPENSEARCH_INDEX=knowledge_base
OPENSEARCH_REGION=us-east-1
OPENSEARCH_PORT=443
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_VECTOR_FIELD=embeddings

# Ticket API
TICKET_API_BASE_URL=
TICKET_API_KEY=
TICKET_API_TIMEOUT_SECONDS=10

# Retrieval
RETRIEVAL_TOP_K=5

# AWS (Optional: leave blank when running with an IAM role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB Conversation History
DYNAMODB_TABLE_NAME=zeco_delta_table
DYNAMODB_REGION=ap-southeast-2
CONVERSATION_HISTORY_MAX_MESSAGES=12

# Uvicorn
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_RELOAD=false
